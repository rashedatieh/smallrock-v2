{
  "manifest_version": 3,
  "name": "Small Rock",
  "version": "2.0.0",
  "description": "Multi-mode prompt rewriter. Ctrl+M ×1 Quick · ×2 Technical · ×3 Planning.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://you.com/chat*",
        "https://www.phind.com/*",
        "https://chat.deepseek.com/*",
        "https://kagi.com/assistant*",
        "https://huggingface.co/chat/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Small Rock",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "rewrite-prompt": {
      "suggested_key": {
        "default": "Ctrl+M"
      },
      "description": "Rewrite active input (×1 Quick ×2 Technical ×3 Planning)"
    }
  }
}
